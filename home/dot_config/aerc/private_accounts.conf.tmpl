{{/*
  aerc accounts — generated by chezmoi. No plaintext passwords or tokens
  are stored in this repo.
    Gmail   : app password, fetched at runtime via *-cred-cmd
              (macOS Keychain / Linux pass).
    Outlook : Microsoft 365 OAuth2 (XOAUTH2). The cred-cmd is the
              ~/.local/bin/aerc-oauth2 wrapper, which serialises
              mutt_oauth2.py (managing ~/.config/aerc/outlook.tokens,
              created by --authorize) so the source/outgoing refreshes
              cannot race and corrupt the token file.
  See docs/SETUP.md §2 for the one-time credential setup.
*/ -}}
{{- $gmailUser := replace "@" "%40" .gmail -}}
{{- $isMac     := eq .chezmoi.os "darwin" -}}
{{- $gmailCred := $isMac | ternary "security find-generic-password -s aerc-gmail -w" "pass show email/gmail" -}}
[Gmail]
from              = {{ .name }} <{{ .gmail }}>
source            = imaps://{{ $gmailUser }}@imap.gmail.com:993
source-cred-cmd   = {{ $gmailCred }}
outgoing          = smtps://{{ $gmailUser }}@smtp.gmail.com:465
outgoing-cred-cmd = {{ $gmailCred }}
copy-to           = [Gmail]/Sent Mail
default           = INBOX
cache-headers     = true
{{ if .outlookMail }}
{{- $outlookUser := replace "@" "%40" .outlookMail -}}
[Outlook]
from              = {{ .name }} <{{ .outlookMail }}>
source            = imaps+xoauth2://{{ $outlookUser }}@outlook.office365.com:993
source-cred-cmd   = ~/.local/bin/aerc-oauth2
outgoing          = smtp+xoauth2://{{ $outlookUser }}@smtp.office365.com:587
outgoing-cred-cmd = ~/.local/bin/aerc-oauth2
copy-to           = Sent Items
default           = INBOX
cache-headers     = true
{{- end }}
