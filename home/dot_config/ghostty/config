# ghostty config — managed by chezmoi
font-family = "JetBrainsMono Nerd Font"
font-size = 14
theme = Gruvbox Dark
background-opacity = 0.95
macos-titlebar-style = transparent
window-save-state = always

# Both Option keys → Alt (Meta in Emacs / `M-x`, vim, readline, etc.)
# Trade-off: macOS's accented character input (Option+v=√, Option+u=¨ …)
# no longer reaches the terminal. Set this back to `left` if needed.
macos-option-as-alt = true
