# ~/.zprofile — managed by chezmoi. Sourced once per login shell.
{{ if eq .chezmoi.os "darwin" -}}
# Homebrew (Apple Silicon)
[ -x /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
{{ end -}}
# Keep ~/.local/bin (chezmoi, mutt_oauth2.py, downloaded binaries) on PATH.
case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) export PATH="$HOME/.local/bin:$PATH" ;;
esac
